# AgentInsight SDK Configuration
# Copy this file to .env and fill in your values

# Required: Your AgentInsight server URL
AGENTINSIGHT_HOST=http://localhost:3000

# Required: Your API keys (find them in AgentInsight Settings > API Keys)
AGENTINSIGHT_PUBLIC_KEY=
AGENTINSIGHT_SECRET_KEY=

# Optional: For testing with live providers
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
